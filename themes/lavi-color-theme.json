{
  "name": "Lavi",
  "semanticHighlighting": true,
  "tokenColors": [
    {
      "scope": "comment, punctuation.definition.comment",
      "settings": {
        "foreground": "#7E7490"
      }
    },
    {
      "scope": "punctuation",
      "settings": {
        "foreground": "#A599E9"
      }
    },
    {
      "scope": [
        "punctuation.definition.parameters",
        "punctuation.section.parameters",
        "punctuation.definition.block",
        "punctuation.section.braces",
        "punctuation.section.brackets",
        "punctuation.section.parens",
        "meta.brace",
        "meta.delimiter",
        "punctuation.definition.arguments",
        "punctuation.definition.list",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#A599E9"
      }
    },
    {
      "scope": "string, punctuation.definition.string",
      "settings": {
        "foreground": "#A5FF90"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.decimal",
        "constant.numeric.hex"
      ],
      "settings": {
        "foreground": "#FFEE80"
      }
    },
    {
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#FF628C"
      }
    },
    {
      "scope": "support.constant",
      "settings": {
        "foreground": "#FF628C"
      }
    },
    {
      "scope": [
        "variable",
        "constant.character",
        "constant.other",
        "variable.other.constant",
        "meta.object-literal.key",
        "meta.property-name",
        "support.type.property-name",
        "variable.other.property",
        "variable.other.object.property",
        "meta.object",
        "meta.object-literal",
        "meta.property.object",
        "meta.member",
        "meta.var.expr"
      ],
      "settings": {
        "foreground": "#E1EFFF"
      }
    },
    {
      "scope": [
        "meta.property-name",
        "variable.object.property",
        "entity.name.tag.yaml",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#2CEDC0"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter",
        "entity.name.variable.parameter"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#2CEDC0"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#FF9D00"
      }
    },
    {
      "scope": "storage, storage.modifier",
      "settings": {
        "foreground": "#FB94FF"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#FB94FF"
      }
    },
    {
      "scope": "entity.name",
      "settings": {
        "foreground": "#FAD000"
      }
    },
    {
      "scope": "entity.other.inherited-class",
      "settings": {
        "fontStyle": "italic underline",
        "foreground": "#80FFBB"
      }
    },
    {
      "scope": "support.type, support.class",
      "settings": {
        "foreground": "#80FFBB"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call.generic",
        "meta.function-call",
        "support.function",
        "meta.method-call"
      ],
      "settings": {
        "foreground": "#FAD000"
      }
    },
    {
      "scope": "support.function, support.macro",
      "settings": {
        "foreground": "#FAD000"
      }
    },
    {
      "scope": "entity.name.tag, entity.other.attribute-name",
      "settings": {
        "foreground": "#E8D3EE"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "markup.deleted.git_gutter"
      ],
      "settings": {
        "foreground": "#40C4C4"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#80BDFF"
      }
    },
    {
      "scope": "support.type.property-name.json",
      "settings": {
        "foreground": "#94C8FF"
      }
    },
    {
      "scope": "entity.name.tag.yaml",
      "settings": {
        "foreground": "#94C8FF"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#BDA5EE"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#80BDFF"
      }
    },
    {
      "scope": "markup.raw.inline, markup.raw.block",
      "settings": {
        "foreground": "#2CEDC0"
      }
    },
    {
      "scope": "markup.inserted.diff, meta.diff.header.to-file",
      "settings": {
        "foreground": "#8BF9A6"
      }
    },
    {
      "scope": "markup.deleted.diff, meta.diff.header.from-file",
      "settings": {
        "foreground": "#F2637E"
      }
    },
    {
      "scope": "markup.changed.diff",
      "settings": {
        "foreground": "#FFD080"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "background": "#EC3A37",
        "foreground": "#EDE7FE"
      }
    },
    {
      "scope": "invalid.deprecated",
      "settings": {
        "background": "#EC3A37",
        "foreground": "#EDE7FE"
      }
    }
  ],
